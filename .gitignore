# Tauri generated schemas are useful locally but can be regenerated.
src-tauri/gen/schemas/

# Android generated build cache.
# Keep the Android project skeleton under src-tauri/gen/android,
# but do not sync Gradle outputs or native build products.
src-tauri/gen/android/.gradle/
src-tauri/gen/android/**/.gradle/
src-tauri/gen/android/**/build/
src-tauri/gen/android/**/.externalNativeBuild/
src-tauri/gen/android/**/.cxx/
src-tauri/gen/android/local.properties
src-tauri/gen/android/**/local.properties
src-tauri/gen/android/key.properties
src-tauri/gen/android/keystore.properties
src-tauri/gen/android/**/key.properties
src-tauri/gen/android/**/keystore.properties
src-tauri/gen/android/app/src/main/jniLibs/
src-tauri/gen/android/app/src/main/assets/tauri.conf.json
src-tauri/gen/android/app/src/main/java/com/quiznest/app/generated/
src-tauri/gen/android/app/tauri.build.gradle.kts
src-tauri/gen/android/app/proguard-tauri.pro
src-tauri/gen/android/app/tauri.properties
src-tauri/gen/android/tauri.settings.gradle

